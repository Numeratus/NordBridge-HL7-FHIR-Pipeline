          <script>// =========================================
// NordBridge - ORU^R01 Source Transformer
// Extract Vital Signs from OBX
// =========================================

var patientId = msg[&apos;PID&apos;][&apos;PID.3&apos;][&apos;PID.3.1&apos;].toString();
var encounterId = msg[&apos;PV1&apos;][&apos;PV1.19&apos;][&apos;PV1.19.1&apos;].toString();
var observationTimeRaw = msg[&apos;OBR&apos;][&apos;OBR.7&apos;][&apos;OBR.7.1&apos;].toString();

// FHIR Date Formatter
function formatDateTime(hl7dt) {
  if (!hl7dt || hl7dt.length &lt; 14) return null;
  return hl7dt.substring(0,4) + &apos;-&apos; + hl7dt.substring(4,6) + &apos;-&apos; + hl7dt.substring(6,8)
    + &apos;T&apos; + hl7dt.substring(8,10) + &apos;:&apos; + hl7dt.substring(10,12) + &apos;:&apos; + hl7dt.substring(12,14) + &apos;+01:00&apos;;
}

channelMap.put(&apos;patientId&apos;, patientId);
channelMap.put(&apos;encounterId&apos;, encounterId);
channelMap.put(&apos;obsTime&apos;, formatDateTime(observationTimeRaw));

// Loop through repeating OBX segments
for (var i = 0; i &lt; msg[&apos;OBX&apos;].length(); i++) {
    var obx = msg[&apos;OBX&apos;][i];
    var loinc = obx[&apos;OBX.3&apos;][&apos;OBX.3.1&apos;].toString();
    var value = obx[&apos;OBX.5&apos;][&apos;OBX.5.1&apos;].toString();
    var unit = obx[&apos;OBX.6&apos;][&apos;OBX.6.1&apos;].toString();

    // 8867-4 is the standard LOINC code for Heart Rate
    if (loinc == &apos;8867-4&apos;) {
        channelMap.put(&apos;heartRate&apos;, value);
        channelMap.put(&apos;hrUnit&apos;, unit);
    } 
    // 8310-5 is the standard LOINC code for Body Temperature
    else if (loinc == &apos;8310-5&apos;) {
        channelMap.put(&apos;temperature&apos;, value);
        channelMap.put(&apos;tempUnit&apos;, unit);
    }
}

logger.info(&apos;NORDBRIDGE: Extracted HR: &apos; + channelMap.get(&apos;heartRate&apos;) + &apos; and Temp: &apos; + channelMap.get(&apos;temperature&apos;));</script>
        </com.mirth.connect.plugins.javascriptstep.JavaScriptStep>
