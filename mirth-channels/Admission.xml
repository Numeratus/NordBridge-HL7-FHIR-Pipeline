        <com.mirth.connect.plugins.javascriptstep.JavaScriptStep version="4.5.2">
          <name>Extract HL7 Fields</name>
          <sequenceNumber>0</sequenceNumber>
          <enabled>true</enabled>
          <script>// =========================================
// NordBridge - ADT^A01 Source Transformer
// Nordpeak Medical Center
// Extracts HL7 v2 fields into channelMap
// =========================================

// --- Patient Identifiers ---
var patientId = msg[&apos;PID&apos;][&apos;PID.3&apos;][&apos;PID.3.1&apos;].toString();
var familyName = msg[&apos;PID&apos;][&apos;PID.5&apos;][&apos;PID.5.1&apos;].toString();
var givenName  = msg[&apos;PID&apos;][&apos;PID.5&apos;][&apos;PID.5.2&apos;].toString();
var middleName = msg[&apos;PID&apos;][&apos;PID.5&apos;][&apos;PID.5.3&apos;].toString();

// --- Demographics ---
var dobRaw = msg[&apos;PID&apos;][&apos;PID.7&apos;][&apos;PID.7.1&apos;].toString();
var genderHL7 = msg[&apos;PID&apos;][&apos;PID.8&apos;][&apos;PID.8.1&apos;].toString();
var phone = msg[&apos;PID&apos;][&apos;PID.13&apos;][&apos;PID.13.1&apos;].toString();

// --- Address ---
var street  = msg[&apos;PID&apos;][&apos;PID.11&apos;][&apos;PID.11.1&apos;].toString();
var city    = msg[&apos;PID&apos;][&apos;PID.11&apos;][&apos;PID.11.3&apos;].toString();
var zip     = msg[&apos;PID&apos;][&apos;PID.11&apos;][&apos;PID.11.5&apos;].toString();
var country = msg[&apos;PID&apos;][&apos;PID.11&apos;][&apos;PID.11.6&apos;].toString();

// --- Visit / Encounter ---
var encounterId   = msg[&apos;PV1&apos;][&apos;PV1.19&apos;][&apos;PV1.19.1&apos;].toString();
var ward          = msg[&apos;PV1&apos;][&apos;PV1.3&apos;][&apos;PV1.3.1&apos;].toString();
var room          = msg[&apos;PV1&apos;][&apos;PV1.3&apos;][&apos;PV1.3.2&apos;].toString();
var bed           = msg[&apos;PV1&apos;][&apos;PV1.3&apos;][&apos;PV1.3.3&apos;].toString();
var admitTimeRaw  = msg[&apos;PV1&apos;][&apos;PV1.44&apos;][&apos;PV1.44.1&apos;].toString();
var doctorId      = msg[&apos;PV1&apos;][&apos;PV1.7&apos;][&apos;PV1.7.1&apos;].toString();
var doctorFamily  = msg[&apos;PV1&apos;][&apos;PV1.7&apos;][&apos;PV1.7.2&apos;].toString();
var doctorGiven   = msg[&apos;PV1&apos;][&apos;PV1.7&apos;][&apos;PV1.7.3&apos;].toString();
var patientClass  = msg[&apos;PV1&apos;][&apos;PV1.2&apos;][&apos;PV1.2.1&apos;].toString(); // I = Inpatient

// --- Convert HL7 gender to FHIR ---
var fhirGender = &apos;unknown&apos;;
if (genderHL7 == &apos;M&apos;) fhirGender = &apos;male&apos;;
else if (genderHL7 == &apos;F&apos;) fhirGender = &apos;female&apos;;
else if (genderHL7 == &apos;O&apos;) fhirGender = &apos;other&apos;;

// --- Format date: HL7 YYYYMMDD → FHIR YYYY-MM-DD ---
function formatDate(hl7date) {
  if (!hl7date || hl7date.length &lt; 8) return null;
  return hl7date.substring(0,4) + &apos;-&apos; + hl7date.substring(4,6) + &apos;-&apos; + hl7date.substring(6,8);
}

// --- Format dateTime: HL7 YYYYMMDDHHMMSS → FHIR ---
function formatDateTime(hl7dt) {
  if (!hl7dt || hl7dt.length &lt; 14) return null;
  return hl7dt.substring(0,4) + &apos;-&apos; + hl7dt.substring(4,6) + &apos;-&apos; + hl7dt.substring(6,8)
    + &apos;T&apos; + hl7dt.substring(8,10) + &apos;:&apos; + hl7dt.substring(10,12) + &apos;:&apos; + hl7dt.substring(12,14) + &apos;+01:00&apos;;
}

// --- Store everything in channelMap ---
channelMap.put(&apos;patientId&apos;,    patientId);
channelMap.put(&apos;familyName&apos;,   familyName);
channelMap.put(&apos;givenName&apos;,    givenName);
channelMap.put(&apos;middleName&apos;,   middleName);
channelMap.put(&apos;dob&apos;,          formatDate(dobRaw));
channelMap.put(&apos;fhirGender&apos;,   fhirGender);
channelMap.put(&apos;phone&apos;,        phone);
channelMap.put(&apos;street&apos;,       street);
channelMap.put(&apos;city&apos;,         city);
channelMap.put(&apos;zip&apos;,          zip);
channelMap.put(&apos;country&apos;,      country);
channelMap.put(&apos;encounterId&apos;,  encounterId);
channelMap.put(&apos;ward&apos;,         ward);
channelMap.put(&apos;room&apos;,         room);
channelMap.put(&apos;bed&apos;,          bed);
channelMap.put(&apos;admitTime&apos;,    formatDateTime(admitTimeRaw));
channelMap.put(&apos;doctorId&apos;,     doctorId);
channelMap.put(&apos;doctorFamily&apos;, doctorFamily);
channelMap.put(&apos;doctorGiven&apos;,  doctorGiven);
channelMap.put(&apos;patientClass&apos;, patientClass);</script>
        </com.mirth.connect.plugins.javascriptstep.JavaScriptStep>
