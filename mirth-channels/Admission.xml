            <script>// =========================================
// Build FHIR R4 Encounter Resource
// Nordpeak Medical Center
// =========================================

var classCode = &apos;IMP&apos;; // inpatient default
var classDisplay = &apos;inpatient encounter&apos;;
if (channelMap.get(&apos;patientClass&apos;) == &apos;E&apos;) {
  classCode = &apos;EMER&apos;;
  classDisplay = &apos;emergency&apos;;
} else if (channelMap.get(&apos;patientClass&apos;) == &apos;O&apos;) {
  classCode = &apos;AMB&apos;;
  classDisplay = &apos;ambulatory&apos;;
}

var fhirPatientId = channelMap.get(&apos;fhirPatientId&apos;);

var encounter = {
  &quot;resourceType&quot;: &quot;Encounter&quot;,
  &quot;meta&quot;: {
    &quot;tag&quot;: [{
      &quot;system&quot;: &quot;http://nordpeak.de/source&quot;,
      &quot;code&quot;: &quot;nordbridge&quot;
    }]
  },
  &quot;identifier&quot;: [
    {
      &quot;system&quot;: &quot;http://nordpeak.de/fhir/encounters&quot;,
      &quot;value&quot;: channelMap.get(&apos;encounterId&apos;)
    }
  ],
  &quot;status&quot;: &quot;in-progress&quot;,
  &quot;class&quot;: {
    &quot;system&quot;: &quot;http://terminology.hl7.org/CodeSystem/v3-ActCode&quot;,
    &quot;code&quot;: classCode,
    &quot;display&quot;: classDisplay
  },
  &quot;type&quot;: [
    {
      &quot;coding&quot;: [
        {
          &quot;system&quot;: &quot;http://snomed.info/sct&quot;,
          &quot;code&quot;: &quot;11429006&quot;,
          &quot;display&quot;: &quot;Consultation&quot;
        }
      ]
    }
  ],
  &quot;subject&quot;: {
    &quot;reference&quot;: &quot;Patient/&quot; + fhirPatientId,
    &quot;display&quot;: channelMap.get(&apos;familyName&apos;) + &apos;, &apos; + channelMap.get(&apos;givenName&apos;)
  },
  &quot;period&quot;: {
    &quot;start&quot;: channelMap.get(&apos;admitTime&apos;)
  },
  &quot;location&quot;: [
    {
      &quot;location&quot;: {
        &quot;display&quot;: channelMap.get(&apos;ward&apos;) + &apos; / &apos; + channelMap.get(&apos;room&apos;) + &apos; / Bed &apos; + channelMap.get(&apos;bed&apos;)
      },
      &quot;status&quot;: &quot;active&quot;
    }
  ],
  &quot;participant&quot;: [
    {
      &quot;type&quot;: [
        {
          &quot;coding&quot;: [
            {
              &quot;system&quot;: &quot;http://terminology.hl7.org/CodeSystem/v3-ParticipationType&quot;,
              &quot;code&quot;: &quot;ATND&quot;,
              &quot;display&quot;: &quot;attender&quot;
            }
          ]
        }
      ],
      &quot;individual&quot;: {
        &quot;display&quot;: &quot;Dr. &quot; + channelMap.get(&apos;doctorGiven&apos;) + &apos; &apos; + channelMap.get(&apos;doctorFamily&apos;)
      }
    }
  ],
  &quot;serviceProvider&quot;: {
    &quot;display&quot;: &quot;Nordpeak Medical Center&quot;
  }
};

channelMap.put(&apos;encounterJson&apos;, JSON.stringify(encounter));</script>
